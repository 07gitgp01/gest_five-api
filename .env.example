# ============================================================
# GestFive API — Variables d'environnement
# Copier en .env et remplir les valeurs manquantes.
# NE JAMAIS committer .env dans git.
# ============================================================

# ── Application ─────────────────────────────────────────────
PROJECT_NAME=GestFive API
ENVIRONMENT=development        # development | production
DEBUG=true
VERSION=1.0.0

# ── Sécurité JWT ─────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Base de données ──────────────────────────────────────────
# Dev local (SQLite — aucune installation requise)
DATABASE_URL=sqlite+aiosqlite:///./gestfive_dev.db

# Dev Docker (PostgreSQL local)
# DATABASE_URL=postgresql+asyncpg://gestfive:gestfive@localhost:5432/gestfive

# Production (Render l'injecte automatiquement depuis la DB liée)
# DATABASE_URL=postgresql://gestfive:password@host:5432/gestfive
# → config.py remplace automatiquement postgresql:// par postgresql+asyncpg://

# Pool de connexions PostgreSQL (ignoré pour SQLite)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ── CORS ─────────────────────────────────────────────────────
# Flutter mobile (Android/iOS) n'envoie pas d'header Origin → CORS inactif
# Flutter web + développement local
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost:5173"]

# Production : utiliser le domaine réel ou ["*"] pour une API mobile pure
# ALLOWED_ORIGINS=["https://app.gestfive.com"]

# Hosts autorisés (TrustedHostMiddleware, production uniquement)
ALLOWED_HOSTS=["localhost","gestfive-api.onrender.com"]

# ── Serveur ──────────────────────────────────────────────────
PORT=8000
WORKERS=1                      # Render starter : 1 worker (512 MB RAM)
LOG_LEVEL=info                 # debug | info | warning | error

# ── Paiements ────────────────────────────────────────────────
PAYMENT_CURRENCY=XOF

# Orange Money
ORANGE_MONEY_BASE_URL=https://api.orange.com/orange-money-webpay/dev/v1
ORANGE_MONEY_MERCHANT_KEY=dev-om-merchant-key
ORANGE_MONEY_WEBHOOK_SECRET=dev-om-webhook-secret

# Moov Money
MOOV_MONEY_BASE_URL=https://api.moov-africa.bj/v1
MOOV_MONEY_API_KEY=dev-moov-api-key
MOOV_MONEY_WEBHOOK_SECRET=dev-moov-webhook-secret

# CinetPay (paiement par carte)
CARD_PAYMENT_BASE_URL=https://api.cinetpay.com/v2
CARD_PAYMENT_API_KEY=dev-card-api-key
CARD_PAYMENT_WEBHOOK_SECRET=dev-card-webhook-secret

# URLs de redirection après paiement carte
PAYMENT_SUCCESS_URL=http://localhost:3000/payment/success
PAYMENT_CANCEL_URL=http://localhost:3000/payment/cancel

# ── Firebase Cloud Messaging ─────────────────────────────────
# Mettre FIREBASE_ENABLED=true et renseigner les 2 champs suivants
# pour activer les push notifications en production.
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=gestfive-dev
# Chemin vers le JSON de compte de service téléchargé depuis Firebase Console
# Sur Render : utiliser un Secret File monté (ex: /etc/secrets/firebase.json)
FIREBASE_CREDENTIALS_PATH=
